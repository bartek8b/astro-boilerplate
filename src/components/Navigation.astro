---
/**
 * Navigation Component
 * Automatically handles active states, external links, and accessibility.
 */

const navLinks = [
  // Modify links upon project requirements
  { name: 'home', href: '/' },
  { name: 'page two', href: '/page-two' },
  { name: 'external', href: 'https://...', external: true },
];

// Get current path for active state logic
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.replace(/\/$/, '');
---

<div class="nav-wrapper">
  <nav id="main-nav" aria-label="Main navigation">
    <ul class="nav-list">
      {
        navLinks.map((link) => {
          // Logical check for active link (handles both /path and /path/)
          const isActive = link.href === currentPath || link.href === pathname;

          return (
            <li>
              <a
                href={link.href}
                class:list={[{ current: isActive }]}
                aria-current={isActive ? 'page' : undefined}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
              >
                {link.name}
                {link.external && (
                  <svg
                    class="icon-external"
                    viewBox="0 0 24 24"
                    width="16"
                    height="16"
                    aria-hidden="true"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                )}
              </a>
            </li>
          );
        })
      }

      <li class="theme-item">
        <button class="theme-toggle-btn" aria-label="Toggle dark mode">
          <span class="sun-icon"
            ><svg
              class="sun-moon-svg"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="feather feather-sun"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg></span
          >
          <span class="moon-icon"
            ><svg
              class="sun-moon-svg"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="feather feather-moon"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg></span
          >
        </button>
      </li>
    </ul>
  </nav>

  <!-- Hamburger button -->
  <button
    class="hamburger-toggle-btn"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="main-nav"
  >
    <svg
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="feather feather-menu"
    >
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <!-- X button initially hidden inline to avoid FOUC-->
  <button
    class="x-toggle-btn"
    aria-label="Close menu"
    style="display: none;"
    aria-controls="main-nav"
  >
    <svg
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="feather feather-x"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
</div>

<style>
  /* Base Layout */
  .nav-wrapper {
    display: flex;
    align-items: center;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
  }

  /* Active link style */
  .current {
    font-weight: 700;
    text-decoration: underline;
  }

  /* External icon alignment */
  .icon-external {
    display: inline-block;
    vertical-align: middle;
    margin-left: 4px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }

  /* Theme toggle visibility logic */
  .sun-icon,
  .moon-icon {
    display: none;
  }
  :global(html[data-theme='light']) .moon-icon {
    display: block;
  }
  :global(html[data-theme='dark']) .sun-icon {
    display: block;
  }

  /* Mobile Overrides */
  @media (max-width: 768px) {
    .hamburger-toggle-btn {
      display: flex;
    }

    nav {
      display: none; /* Controlled by JS */
      position: absolute;
      left: 0;
      width: 100%;
      z-index: 100;
    }

    .nav-list {
      flex-direction: column;
      padding: 2rem;
      gap: 1.5rem;
    }
  }

  /* Buttons Styling */
  .hamburger-toggle-btn,
  .x-toggle-btn,
  .theme-toggle-btn {
    cursor: pointer;
    color: currentColor;
    padding: 0.5rem;
  }
</style>
