---
/**
 * Embla carousel library installed from npm through ../scripts/embla-carousel.js
 */
---

<div class="embla">
  <div class="embla__viewport">
    <div class="embla__container">
      <div class="embla__slide">1</div>
      <div class="embla__slide">2</div>
      <div class="embla__slide">3</div>
      <div class="embla__slide">4</div>
      <div class="embla__slide">5</div>
      <div class="embla__slide">6</div>
      <div class="embla__slide">7</div>
      <div class="embla__slide">8</div>
    </div>
  </div>

  <div class="embla__controls">
    <div class="embla__nav-btns-container">
      <button class="embla__prev">&#706;</button>
      <button class="embla__next">&#707;</button>
    </div>
    <div class="embla__dots"></div>
    <template id="embla-dot-template">
      <button class="embla__dot" aria-label="Go to slide"> </button>
    </template>
  </div>
</div>

<style>
  .embla {
    --slide-size: 50%;
    --slide-size-md-up: 100%; /* Mobile (max-width: 768px) */
    --slide-spacing: 16px;
    --slide-spacing-md-up: 8px; /* Mobile (max-width: 768px) */
  }
  .embla__viewport {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    touch-action: pan-y pinch-zoom;
    margin-left: calc(var(--slide-spacing) * -1);
  }

  .embla__slide {
    flex: 0 0 var(--slide-size);
    min-width: 0;
    padding-left: var(--slide-spacing);
    border: 1px solid black;
  }

  .embla__nav-btns-container button {
    border-radius: 999rem;
    border: 1px solid black;
    aspect-ratio: 1 / 1;
    width: 32px;
    height: auto;
  }

  .embla__dot {
    opacity: 0.5;
    border-radius: 999rem;
    background-color: black;
    aspect-ratio: 1 / 1;
    width: 8px;
    height: auto;
  }

  .embla__dot--selected {
    opacity: 1;
    width: 16px;
    aspect-ratio: 2 / 1;
  }

  @media (max-width: 768px) {
    .embla__container {
      margin-left: calc(var(--slide-spacing-md-up) * -1); /* Renders -20px */
    }

    .embla__slide {
      flex: 0 0 var(--slide-size-md-up);
    }
  }
</style>

<script>
  import '../scripts/embla-carousel.js';
</script>
