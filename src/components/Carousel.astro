---
/**
 * Embla carousel library installed from npm through ../scripts/embla-carousel.js
 */

import { Image } from 'astro:assets';

interface Props {
  images: {
    src: ImageMetadata;
    alt: string;
  }[];
}

const { images } = Astro.props;
---

<div class="embla" aria-roledescription="carousel" aria-label="Gallery">
  <div class="embla__viewport">
    <div class="embla__container">
      {
        images.map((img, index) => (
          <div
            class="embla__slide"
            role="group"
            aria-roledescription="slide"
            aria-label={`${index + 1} of ${images.length}`}
          >
            <Image
              src={img.src}
              alt={img.alt}
              class="embla__img"
              widths={[400, 800, 1200]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </div>
        ))
      }
    </div>
  </div>

  <div class="embla__controls">
    <div class="embla__nav-btns-container">
      <button class="embla__prev" aria-label="Previous slide">&#706;</button>
      <button class="embla__next" aria-label="Next slide">&#707;</button>
    </div>

    <div
      class="embla__dots"
      role="tablist"
      aria-label="Select slide to display"
    >
    </div>
    <template id="embla-dot-template">
      <!-- aria-label has to match content within this line in embla-carousel.js: return html.replace('Go to slide', `Go to slide ${index + 1}`); -->
      <button
        class="embla__dot"
        role="tab"
        aria-selected="false"
        aria-label="Go to slide"
        tabindex="-1"
      >
      </button>
    </template>
  </div>
</div>

<style>
  .embla {
    --slide-size: 50%;
    --slide-size-mobile: 100%; /* Mobile (max-width: 768px) */
    --slide-spacing: 16px;
    --slide-spacing-mobile: 8px; /* Mobile (max-width: 768px) */
  }
  .embla__viewport {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    touch-action: pan-y pinch-zoom;
    margin-left: calc(var(--slide-spacing) * -1);
  }

  .embla__slide {
    flex: 0 0 var(--slide-size);
    min-width: 0;
    padding-left: var(--slide-spacing);
    border: 1px solid black;
  }

  .embla__nav-btns-container button {
    border-radius: 999rem;
    border: 1px solid black;
    aspect-ratio: 1 / 1;
    width: 32px;
    height: auto;
  }

  .embla__dot {
    opacity: 0.5;
    border-radius: 999rem;
    background-color: black;
    aspect-ratio: 1 / 1;
    width: 8px;
    height: auto;
  }

  .embla__dot--selected {
    opacity: 1;
    width: 16px;
    aspect-ratio: 2 / 1;
  }

  @media (max-width: 768px) {
    .embla__container {
      margin-left: calc(var(--slide-spacing-mobile) * -1); /* Renders -20px */
    }

    .embla__slide {
      flex: 0 0 var(--slide-size-mobile);
    }
  }
</style>

<script>
  import '../scripts/embla-carousel.js';
</script>

