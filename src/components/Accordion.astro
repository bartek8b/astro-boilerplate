---
/**
 * Automated via props, manually styled via CSS placeholders.
 */

interface Props {
  items: {
    title: string;
    para?: string;
    table?: {
      headers: string[];
      rows: string[][];
    };
  }[];
}

const { items } = Astro.props;
---

<div class="accordion">
  {
    items.map((item) => {
      const uniqueId = crypto.randomUUID();

      return (
        <div class="accordion-item">
          <button
            id={`btn-${uniqueId}`}
            class="accordion-header"
            aria-expanded="false"
            aria-controls={`para-${uniqueId}`}
          >
            {item.title}
            <span class="icon-plus-minus" aria-hidden="true">
              +
            </span>
          </button>

          <div
            id={`para-${uniqueId}`}
            class="accordion-content"
            role="region"
            aria-labelledby={`btn-${uniqueId}`}
          >
            {item.para && <p>{item.para}</p>}

            {item.table && (
              <table>
                <colgroup>
                  {item.table.headers.map((_, i) => (
                    <col class={`col-${i}`} />
                  ))}
                </colgroup>
                <thead>
                  <tr>
                    {item.table.headers.map((h, i) => (
                      <th class={`col-${i}`}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {item.table.rows.map((row) => (
                    <tr>
                      {row.map((cell, i) => (
                        <td class={`col-${i}`}>{cell}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>
        </div>
      );
    })
  }
</div>

<style>
  /* --- CUSTOMIZE YOUR LAYOUT HERE --- */

  .accordion {
    overflow: hidden;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0; /* TODO: Add custom styling */
  }

  .accordion-item {
    display: flex;
    flex-direction: column;
    gap: 0; /* TODO: Add custom styling */
  }

  .accordion-item > * {
    padding-inline: 0; /* TODO: Add custom styling */
  }

  /* Styling of expanded item */
  .accordion-item.expanded .accordion-header,
  .accordion-header:active {
    background-color: tomato; /* TODO: Add custom styling and keep it within @media: hover */
    color: green; /* TODO: Add custom styling and keep it within @media: hover */
  }

  .accordion-item.expanded {
    margin-bottom: 0; /* TODO: Add custom styling */
  }

  .accordion-header {
    width: 100%;
    background-color: transparent;
    color: inherit;
    border: 0; /* TODO: Add custom styling */
    border-radius: 0; /* TODO: Add custom styling */
    cursor: pointer;
    text-align: start;
    padding-block: 0; /* TODO: Add custom styling */
    padding-inline: 0; /* TODO: Add custom styling */
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .accordion-header:active,
  .accordion-item.expanded .accordion-header {
    background-color: 0; /* TODO: Add custom styling */
    color: 0; /* TODO: Add custom styling */
  }

  .icon-plus-minus {
    font-size: 0; /* TODO: Add custom styling */
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    display: flex;
    flex-direction: column;
    gap: 0; /* TODO: Add custom styling */ /* TODO: Add custom styling */
  }

  .accordion-content > table {
    width: 100%;
    border-collapse: collapse;
  }

  .accordion-content table .col-1 {
    width: 25%;
    text-align: center;
  }

  .accordion-content > table .col-0 {
    text-align: start;
  }

  .accordion-content > table th,
  .accordion-content > table td {
    border-bottom: 0; /* TODO: Add custom styling */ /* TODO: Add custom styling */
    padding-block: 0; /* TODO: Add custom styling */ /* TODO: Add custom styling */
  }

  .accordion-content table th {
    font-weight: bold;
  }

  @media (hover: hover) {
    .accordion-header:hover {
      background-color: tomato; /* TODO: Add custom styling */
      color: green; /* TODO: Add custom styling */
    }
  }
</style>

<script>
  function initAccordion() {
    const accordionHeaders = document.querySelectorAll('.accordion-header');

    accordionHeaders.forEach((button) => {
      button.addEventListener('click', () => {
        const accordionItem = button.parentElement as HTMLElement;
        if (!accordionItem) return;

        const content = accordionItem.querySelector(
          '.accordion-content',
        ) as HTMLElement;
        if (!content) return;

        // Logic: Close other elements (Single Open Mode)
        document.querySelectorAll('.accordion-item').forEach((item) => {
          const otherItem = item as HTMLElement;
          if (
            otherItem !== accordionItem &&
            otherItem.classList.contains('expanded')
          ) {
            const otherContent = otherItem.querySelector(
              '.accordion-content',
            ) as HTMLElement;
            const otherIcon = otherItem.querySelector('.icon-plus-minus');
            const otherButton = otherItem.querySelector('.accordion-header');

            if (otherContent) {
              if (otherContent.style.maxHeight === 'none') {
                otherContent.style.maxHeight = otherContent.scrollHeight + 'px';
              }
              setTimeout(() => {
                otherContent.style.maxHeight = '0';
              }, 10);
            }

            otherItem.classList.remove('expanded');
            if (otherIcon) otherIcon.textContent = '+';
            if (otherButton) otherButton.setAttribute('aria-expanded', 'false');
          }
        });

        // Toggle current element state
        const isExpanded = accordionItem.classList.toggle('expanded');
        button.setAttribute('aria-expanded', String(isExpanded));

        if (isExpanded) {
          content.style.maxHeight = content.scrollHeight + 'px';
          const icon = accordionItem.querySelector('.icon-plus-minus');
          if (icon) icon.textContent = '-';

          content.addEventListener('transitionend', function handler() {
            if (accordionItem.classList.contains('expanded')) {
              content.style.maxHeight = 'none';
            }
            content.removeEventListener('transitionend', handler);
          });
        } else {
          if (content.style.maxHeight === 'none') {
            content.style.maxHeight = content.scrollHeight + 'px';
          }
          setTimeout(() => {
            content.style.maxHeight = '0';
          }, 10);
          const icon = accordionItem.querySelector('.icon-plus-minus');
          if (icon) icon.textContent = '+';
        }
      });
    });
  }

  // Initial load & View Transitions support
  initAccordion();
  document.addEventListener('astro:after-swap', initAccordion);
</script>

