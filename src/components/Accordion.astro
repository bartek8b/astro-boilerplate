---
/**
 * ACCORDION CONTAINER
 * This component acts as a pure wrapper for AccordionItem components
 * passed via MDX slots, enabling dynamic content authoring.
 */
---

<div class="accordion">
  <slot />
</div>

<style>
  /* --- CUSTOMIZE YOUR LAYOUT HERE --- */

  .accordion {
    overflow: hidden;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0; /* TODO: Add custom styling */
  }

  .accordion :global(.accordion-item) {
    display: flex;
    flex-direction: column;
    gap: 0; /* TODO: Add custom styling */
  }

  .accordion :global(.accordion-item > *) {
    padding-inline: 0; /* TODO: Add custom styling */
  }

  /* Styling of expanded item */
  .accordion :global(.accordion-item.expanded .accordion-header) {
    background-color: red; /* TODO: Add custom styling and keep it within @media: hover */
  }

  .accordion :global(.accordion-item.expanded) {
    margin-bottom: 0; /* TODO: Add custom styling */
  }

  .accordion :global(.accordion-header) {
    width: 100%;
    background-color: tomato;
    color: green; /* TODO: Add custom styling and keep it within @media: hover */
    border: 0; /* TODO: Add custom styling */
    border-radius: 0; /* TODO: Add custom styling */
    cursor: pointer;
    text-align: start;
    padding-block: 0; /* TODO: Add custom styling */
    padding-inline: 0; /* TODO: Add custom styling */
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .accordion :global(.accordion-item.expanded .accordion-header),
  .accordion :global(.accordion-header:active) {
    background-color: red; /* TODO: Add custom styling */
    color: green; /* TODO: Add custom styling */
  }

  .accordion :global(.icon-plus-minus) {
    font-size: 0; /* TODO: Add custom styling */
  }

  .accordion :global(.accordion-content) {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    display: flex;
    flex-direction: column;
    gap: 0; /* TODO: Add custom styling */ /* TODO: Add custom styling */
  }

  @media (hover: hover) {
    .accordion :global(.accordion-header:hover) {
      background-color: red; /* TODO: Add custom styling */
    }
  }
</style>

<script>
  function initAccordion() {
    const accordionHeaders = document.querySelectorAll('.accordion-header');

    accordionHeaders.forEach((button) => {
      button.addEventListener('click', () => {
        const accordionItem = button.parentElement as HTMLElement;
        if (!accordionItem) return;

        const content = accordionItem.querySelector(
          '.accordion-content',
        ) as HTMLElement;
        if (!content) return;

        // Logic: Close other elements (Single Open Mode)
        document.querySelectorAll('.accordion-item').forEach((item) => {
          const otherItem = item as HTMLElement;
          if (
            otherItem !== accordionItem &&
            otherItem.classList.contains('expanded')
          ) {
            const otherContent = otherItem.querySelector(
              '.accordion-content',
            ) as HTMLElement;
            const otherIcon = otherItem.querySelector('.icon-plus-minus');
            const otherButton = otherItem.querySelector('.accordion-header');

            if (otherContent) {
              if (otherContent.style.maxHeight === 'none') {
                otherContent.style.maxHeight = otherContent.scrollHeight + 'px';
              }
              setTimeout(() => {
                otherContent.style.maxHeight = '0';
              }, 10);
            }

            otherItem.classList.remove('expanded');
            if (otherIcon) otherIcon.textContent = '+';
            if (otherButton) otherButton.setAttribute('aria-expanded', 'false');
          }
        });

        // Toggle current element state
        const isExpanded = accordionItem.classList.toggle('expanded');
        button.setAttribute('aria-expanded', String(isExpanded));

        if (isExpanded) {
          content.style.maxHeight = content.scrollHeight + 'px';
          const icon = accordionItem.querySelector('.icon-plus-minus');
          if (icon) icon.textContent = '-';

          content.addEventListener('transitionend', function handler() {
            if (accordionItem.classList.contains('expanded')) {
              content.style.maxHeight = 'none';
            }
            content.removeEventListener('transitionend', handler);
          });
        } else {
          if (content.style.maxHeight === 'none') {
            content.style.maxHeight = content.scrollHeight + 'px';
          }
          setTimeout(() => {
            content.style.maxHeight = '0';
          }, 10);
          const icon = accordionItem.querySelector('.icon-plus-minus');
          if (icon) icon.textContent = '+';
        }
      });
    });
  }

  // Initial load & View Transitions support
  initAccordion();
  document.addEventListener('astro:after-swap', initAccordion);
</script>
