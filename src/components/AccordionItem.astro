---
/**
 * ACCORDION ITEM COMPONENT
 * Controls a single expandable row within an Accordion.
 * - Uses 'crypto.randomUUID()' to ensure unique IDs for ARIA attributes.
 * - Accessibility: Links the button with the content panel via 'aria-controls' and 'aria-labelledby'.
 * - Content: Injected via the default <slot />.
 */

interface Props {
  title: string;
}

const { title } = Astro.props;
const uniqueId = crypto.randomUUID();
---

<div class="accordion-item">
  <button
    id={`btn-${uniqueId}`}
    class="accordion-header"
    aria-expanded="false"
    aria-controls={`para-${uniqueId}`}
  >
    {title}
    <span class="icon-plus-minus" aria-hidden="true">+</span>
  </button>

  <div
    id={`para-${uniqueId}`}
    class="accordion-content"
    role="region"
    aria-labelledby={`btn-${uniqueId}`}
  >
    <slot />
  </div>
</div>
